# 邮件服务配置
# 启用真实邮件发送（设置为true启用）
ENABLE_EMAIL_SENDING=true

# SMTP服务器配置
# 常见邮箱SMTP服务器：
# QQ邮箱: smtp.qq.com (端口: 587)
# Gmail: smtp.gmail.com (端口: 587)
# 163邮箱: smtp.163.com (端口: 465或994)
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587

# 您的邮箱地址
SMTP_USERNAME=641077621@qq.com

# 邮箱授权码（不是登录密码！）
# QQ邮箱: 需要在账户设置中开启SMTP服务并获取授权码
# Gmail: 需要使用应用专用密码
SMTP_PASSWORD=dzqomabbnkdhbbci

# 发送者邮箱（通常与SMTP_USERNAME相同）
SENDER_EMAIL=641077621@qq.com

# 应用配置
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15
